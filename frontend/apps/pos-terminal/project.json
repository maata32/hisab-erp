{
  "name": "pos-terminal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/pos-terminal/src",
  "tags": ["scope:pos", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/pos-terminal",
        "index": "apps/pos-terminal/src/index.html",
        "main": "apps/pos-terminal/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/pos-terminal/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/pos-terminal/src/favicon.ico",
          "apps/pos-terminal/src/assets",
          "apps/pos-terminal/src/manifest.webmanifest",
          {
            "glob": "**/*",
            "input": "node_modules/primeicons",
            "output": "/assets/primeicons"
          }
        ],
        "styles": [
          "node_modules/primeng/resources/themes/lara-light-blue/theme.css",
          "node_modules/primeng/resources/primeng.min.css",
          "node_modules/primeicons/primeicons.css",
          "apps/pos-terminal/src/styles.scss"
        ],
        "serviceWorker": true,
        "ngswConfigPath": "apps/pos-terminal/ngsw-config.json"
      },
      "configurations": {
        "production": {
          "budgets": [
            { "type": "initial", "maximumWarning": "1.5mb", "maximumError": "3mb" }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/pos-terminal/src/environments/environment.ts",
              "with": "apps/pos-terminal/src/environments/environment.prod.ts"
            }
          ]
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true,
          "serviceWorker": false
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": { "buildTarget": "pos-terminal:build:production" },
        "development": { "buildTarget": "pos-terminal:build:development" }
      },
      "options": {
        "port": 4201,
        "proxyConfig": "apps/pos-terminal/proxy.conf.json"
      },
      "defaultConfiguration": "development"
    },
    "lint": { "executor": "@nx/eslint:lint" },
    "test": { "executor": "@nx/jest:jest", "options": { "jestConfig": "apps/pos-terminal/jest.config.ts" } }
  }
}
