# Hisab ERP — root .env.example (development)
#
# Copy to .env at the repo root for local non-Docker runs of the backend
# (e.g. `make backend-run`). The dev Docker stack does NOT read this file —
# it has its own values inlined in infra/docker/dev/docker-compose.yml.
#
# For PRODUCTION, do NOT use this file. Use /etc/hisaberp/.env on the host
# (template at infra/docker/prod/.env.example).

# ---------- core ----------
SPRING_PROFILES_ACTIVE=dev
APP_VERSION=0.1.0-SNAPSHOT
SERVER_PORT=8080

# ---------- database ----------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/hisaberp
SPRING_DATASOURCE_USERNAME=minierp
SPRING_DATASOURCE_PASSWORD=minierp

# ---------- redis ----------
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ---------- security ----------
JWT_SECRET=DEV_SECRET_AT_LEAST_32_CHARACTERS_LONG_FOR_HS256_OK
JWT_ACCESS_TTL=PT60M
JWT_REFRESH_TTL=P7D
PII_ENCRYPTION_KEY=dev-pii-key-change-in-prod-32chars

# ---------- public URLs / CORS ----------
APP_PUBLIC_URL=http://localhost:8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201

# ---------- mail ----------
# Dev: Mailpit/MailHog catches everything (no auth, no TLS). View at http://localhost:8025
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=noreply@hisaberp.local
#
# Prod — FREE option: Gmail SMTP (~500 emails/day). Requires 2-Step Verification on the
# Google account, then create an "App password" (Google account → Security → App passwords)
# and use it as MAIL_PASSWORD. MAIL_FROM must equal the Gmail address.
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USERNAME=your-account@gmail.com
#   MAIL_PASSWORD=your-16-char-app-password
#   MAIL_SMTP_AUTH=true
#   MAIL_SMTP_STARTTLS=true
#   MAIL_FROM=your-account@gmail.com
# Other free transactional tiers (better for real volume): Brevo (300/day), Mailjet (200/day).

# ---------- object storage (MinIO in dev) ----------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hisaberp-documents

# ---------- SMS providers (stubbed in V1, see ADR-…) ----------
SMS_DEFAULT_PROVIDER=CHINGUITEL
CHINGUITEL_API_URL=
CHINGUITEL_API_KEY=
MAURITEL_API_URL=
MAURITEL_API_KEY=

# ---------- observability ----------
TRACING_SAMPLE_RATE=1.0
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SQL=WARN
