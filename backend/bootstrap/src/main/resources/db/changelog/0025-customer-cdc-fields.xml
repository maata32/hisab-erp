<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!-- G2: Customer.defaultPriceTierId (CDC §3.7.4) -->
    <changeSet id="0025-customer-default-price-tier" author="mini-erp">
        <addColumn tableName="customers">
            <column name="default_price_tier_id" type="uuid"/>
        </addColumn>
        <createIndex tableName="customers" indexName="idx_customers_price_tier">
            <column name="default_price_tier_id"/>
        </createIndex>
    </changeSet>

    <!-- G3: Customer.notificationPreferences (CDC §3.12.2) -->
    <changeSet id="0025-customer-notification-prefs" author="mini-erp">
        <addColumn tableName="customers">
            <column name="notification_preferences" type="jsonb"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
