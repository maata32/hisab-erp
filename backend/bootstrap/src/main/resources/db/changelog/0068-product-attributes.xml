<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
      Variant attributes catalog. An Attribute is a variant axis (Couleur, Taille);
      AttributeValue is one of its values (Rouge, M). product_attribute_values records
      which values a product enables; variant_attribute_values links a generated variant
      to its exact value combination (source of truth behind product_variants.attributes).
    -->
    <changeSet id="0068-attributes" author="hisab-erp">
        <createTable tableName="attributes">
            <column name="id" type="uuid" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="name" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="sort_order" type="int" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="is_active" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="created_by" type="uuid"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="updated_by" type="uuid"/>
            <column name="version" type="bigint" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="attributes" columnNames="tenant_id,name"
                             constraintName="uk_attributes_tenant_name"/>
        <createIndex tableName="attributes" indexName="idx_attributes_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="0068-attribute-values" author="hisab-erp">
        <createTable tableName="attribute_values">
            <column name="id" type="uuid" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="attribute_id" type="uuid"><constraints nullable="false"/></column>
            <column name="value" type="varchar(100)"><constraints nullable="false"/></column>
            <column name="code" type="varchar(32)"/>
            <column name="sort_order" type="int" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="is_active" type="boolean" defaultValueBoolean="true"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="created_by" type="uuid"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="updated_by" type="uuid"/>
            <column name="version" type="bigint" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="attribute_values" columnNames="attribute_id,value"
                             constraintName="uk_attribute_values_attr_value"/>
        <createIndex tableName="attribute_values" indexName="idx_attribute_values_attribute">
            <column name="attribute_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="0068-product-attribute-values" author="hisab-erp">
        <createTable tableName="product_attribute_values">
            <column name="id" type="uuid" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="product_id" type="uuid"><constraints nullable="false"/></column>
            <column name="attribute_value_id" type="uuid"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="created_by" type="uuid"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="updated_by" type="uuid"/>
            <column name="version" type="bigint" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="product_attribute_values" columnNames="product_id,attribute_value_id"
                             constraintName="uk_pav_product_value"/>
        <createIndex tableName="product_attribute_values" indexName="idx_pav_product">
            <column name="product_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="0068-variant-attribute-values" author="hisab-erp">
        <createTable tableName="variant_attribute_values">
            <column name="id" type="uuid" defaultValueComputed="uuid_generate_v4()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="variant_id" type="uuid"><constraints nullable="false"/></column>
            <column name="attribute_value_id" type="uuid"><constraints nullable="false"/></column>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="created_by" type="uuid"/>
            <column name="updated_at" type="timestamptz" defaultValueComputed="now()"><constraints nullable="false"/></column>
            <column name="updated_by" type="uuid"/>
            <column name="version" type="bigint" defaultValueNumeric="0"><constraints nullable="false"/></column>
        </createTable>
        <addUniqueConstraint tableName="variant_attribute_values" columnNames="variant_id,attribute_value_id"
                             constraintName="uk_vav_variant_value"/>
        <createIndex tableName="variant_attribute_values" indexName="idx_vav_variant">
            <column name="variant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="0068-attributes-rls" author="hisab-erp">
        <sql splitStatements="false">
            DO $$
            DECLARE
                t text;
                tables text[] := ARRAY[
                    'attributes',
                    'attribute_values',
                    'product_attribute_values',
                    'variant_attribute_values'
                ];
            BEGIN
                FOREACH t IN ARRAY tables LOOP
                    EXECUTE format('ALTER TABLE %I ENABLE ROW LEVEL SECURITY', t);
                    EXECUTE format('ALTER TABLE %I FORCE ROW LEVEL SECURITY', t);

                    EXECUTE format('DROP POLICY IF EXISTS tenant_isolation_select ON %I', t);
                    EXECUTE format(
                        'CREATE POLICY tenant_isolation_select ON %I
                            FOR SELECT
                            USING (tenant_id = app_current_tenant() OR app_current_tenant() IS NULL)',
                        t);

                    EXECUTE format('DROP POLICY IF EXISTS tenant_isolation_modify ON %I', t);
                    EXECUTE format(
                        'CREATE POLICY tenant_isolation_modify ON %I
                            FOR ALL
                            USING (tenant_id = app_current_tenant() OR app_current_tenant() IS NULL)
                            WITH CHECK (tenant_id = app_current_tenant() OR app_current_tenant() IS NULL)',
                        t);
                END LOOP;
            END
            $$;
        </sql>
    </changeSet>

</databaseChangeLog>
