<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        POS scope simplification: remove manual cash-in/cash-out drawer movements
        and refund (cross-session) sales. Session-level void (same session) is kept.

        Per user direction: "Tout supprimer (données + endpoints)".
    -->

    <changeSet id="0033-purge-pay-in-out-movements" author="hisab-erp">
        <sql>
            DELETE FROM cash_movements WHERE type IN ('PAY_IN', 'PAY_OUT');
        </sql>
    </changeSet>

    <changeSet id="0033-purge-refunded-sale-lines" author="hisab-erp">
        <sql>
            DELETE FROM sale_lines
            WHERE sale_id IN (SELECT id FROM sales WHERE status = 'REFUNDED');
        </sql>
    </changeSet>

    <changeSet id="0033-clear-original-sale-id-on-survivors" author="hisab-erp">
        <sql>
            UPDATE sales SET original_sale_id = NULL
            WHERE original_sale_id IN (SELECT id FROM sales WHERE status = 'REFUNDED');
        </sql>
    </changeSet>

    <changeSet id="0033-purge-refunded-sales" author="hisab-erp">
        <sql>
            DELETE FROM sales WHERE status = 'REFUNDED';
        </sql>
    </changeSet>

    <changeSet id="0033-drop-original-sale-id" author="hisab-erp">
        <dropIndex tableName="sales" indexName="idx_sales_original"/>
        <dropColumn tableName="sales" columnName="original_sale_id"/>
    </changeSet>

</databaseChangeLog>
