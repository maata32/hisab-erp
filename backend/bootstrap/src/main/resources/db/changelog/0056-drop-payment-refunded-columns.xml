<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        Drop the vestigial refund-soft-void columns on payments. They belonged to
        the old model where refunding flipped the original inflow to REFUNDED and
        linked it to a refund payment. Refunds are now plain outgoing payments
        (CUSTOMER_REFUND / SUPPLIER_REFUND) reconciled through the allocations
        table, and no code reads these columns anymore. The earlier backfill
        (changeset 0053) consumed refunded_at while it still existed, so dropping
        them now is safe.
    -->

    <changeSet id="0056-drop-payment-refunded-columns" author="hisab-erp">
        <dropIndex tableName="payments" indexName="idx_payments_refunded_by"/>
        <dropColumn tableName="payments">
            <column name="refunded_at"/>
            <column name="refunded_by_payment_id"/>
        </dropColumn>
    </changeSet>

</databaseChangeLog>
