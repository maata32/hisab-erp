              (uuid_generate_v4(), 'BUSINESS',   'Business',  10000.00, 100000.00, 10, 30, 30000, true, '{"thermalPrinter":true,"offlinePos":true,"multiWarehouse":true,"barcodes":true,"lotExpiry":true,"hr":true,"reporting":true}'::jsonb, '["pos","catalog","inventory","sales","customer","payment","lot-expiry","hr","reporting","expense","purchase"]'::jsonb),
              (uuid_generate_v4(), 'ENTERPRISE', 'Enterprise',     0.00,      0.00, NULL, NULL, NULL, true, '{"all":true,"customSla":true}'::jsonb, '["all"]'::jsonb);
        </sql>
    </changeSet>

</databaseChangeLog>
