# Copy to /etc/hisaberp/.env on the prod host (chmod 600, owned by root).
# All values are REQUIRED unless marked optional.

# --- Domain & TLS ---
# A records required at the host IPv4: app.  pos.  api.  files.  (grafana. for the obs addon).
# files.<domain> serves stored files (MinIO S3 read API) and is REQUIRED for attachments/images.
ROOT_DOMAIN=hisaberp.example.com
ACME_EMAIL=ops@example.com

# --- Image registry (CI pushes here, prod compose pulls from here) ---
IMAGE_REGISTRY=ghcr.io/your-org
APP_VERSION=v0.1.0

# --- Secrets (rotate quarterly) ---
# POSTGRES_PASSWORD = owner/admin role 'hisaberp' (Liquibase/DDL only).
# APP_DB_PASSWORD   = runtime role 'hisaberp_app' (NOSUPERUSER/NOBYPASSRLS; the Spring datasource).
#   For an EXISTING database, also run once as admin: ALTER ROLE hisaberp_app PASSWORD '<APP_DB_PASSWORD>';
POSTGRES_PASSWORD=CHANGE_ME_with_openssl_rand_-base64_32
APP_DB_PASSWORD=CHANGE_ME_with_openssl_rand_-base64_32
REDIS_PASSWORD=CHANGE_ME_with_openssl_rand_-base64_32
JWT_SECRET=CHANGE_ME_with_openssl_rand_-base64_48
PII_ENCRYPTION_KEY=CHANGE_ME_32_chars_exactly_pls!!
MINIO_ROOT_PASSWORD=CHANGE_ME_with_openssl_rand_-base64_32
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_with_openssl_rand_-base64_24

# --- Email (configure when SMTP provider chosen; flows like password reset no-op until set) ---
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# --- First-run platform super-admin bootstrap ---
# Prod ships NO seed. Set these for the FIRST deploy ONLY; the backend then creates the platform
# super-admin (idempotent — no-ops once one exists). Afterwards BLANK them and rotate the password.
# Sign in via the platform login (POST /api/v1/auth/platform-login).
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Platform Super Admin

# --- Off-host backups (STRONGLY recommended) ---
# Replicate the daily pg dumps to S3-compatible object storage (e.g. Hetzner Object Storage).
# Without this, backups live only on the same VM and are lost if it dies. Leave blank to disable.
# Create the bucket + S3 credentials in the provider console first.
BACKUP_S3_ENDPOINT=
BACKUP_S3_REGION=eu-central
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
# BACKUP_SYNC_INTERVAL=86400    # seconds between syncs (default: daily)
